# Domain for automatic HTTPS (Let's Encrypt)
DOMAIN=your-domain.com

# 32-byte hex string (64 characters) used for at-rest encryption of secrets.
# Generate with: openssl rand -hex 32
KIWI_ENCRYPTION_KEY=

# Secret token required to hit /admin/* endpoints and for bootstrapping.
# Generate with: openssl rand -hex 32
KIWI_SERVER_TOKEN=

# CORS Allowed Origins (Comma-separated list of origins for the dashboard frontend).
# Do NOT use '*' in production.
# Example: https://app.your-domain.com
KIWI_CORS_ALLOWED_ORIGINS=https://app.your-domain.com

# Database Credentials
POSTGRES_USER=kiwi
POSTGRES_PASSWORD=kiwipassword
POSTGRES_DB=kiwi

# Join token for the managed daemon
# After running bootstrap.sh, mint a daemon join token via the API or DB
# and restart the kiwidaemon container with this value.
KIWI_JOIN_TOKEN=
